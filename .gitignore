# ========================
# Dependencies
# ========================
**/node_modules/
**/package-lock.json

# ========================
# Environment / Secrets (NEVER commit these)
# ========================
**/.env
**/.env.*
**/.env.local
**/.env.development
**/.env.production
**/.env.staging
**/*.pem
**/*.key
**/*.cert

# ========================
# Logs
# ========================
**/logs/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# ========================
# Build / Dist output
# ========================
frontend/dist/
frontend/dist-ssr/
backend/dist/
backend/build/

# ========================
# Database & Dumps
# ========================
**/*.sql.bak
**/*.dump
**/*.db
**/*.sqlite
**/*.sqlite3

# ========================
# OS Files
# ========================
.DS_Store
**/Thumbs.db
**/Desktop.ini

# ========================
# Editor / IDE
# ========================
.vscode/*
!.vscode/extensions.json
.idea/
**/*.suo
**/*.ntvs*
**/*.njsproj
**/*.sln
**/*.sw?

# ========================
# Misc
# ========================
**/.cache/
**/tmp/
**/temp/
**/coverage/
